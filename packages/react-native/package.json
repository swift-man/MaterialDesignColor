{
  "name": "@swift-man/material-design-color",
  "version": "2.0.0",
  "description": "Material Design color palette for React Native and Expo.",
  "license": "MIT",
  "author": "swift-man",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swift-man/MaterialDesignColor.git",
    "directory": "packages/react-native"
  },
  "keywords": [
    "material",
    "material-design",
    "material3",
    "colors",
    "react-native",
    "expo"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
