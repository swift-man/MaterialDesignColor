{
  "name": "@swift-man/material-design-color",
  "version": "2.0.0",
  "type": "module",
  "description": "Material Design 3 color schemes (light/dark, 48 roles) and Material 2 palette for TypeScript / JavaScript. Framework-agnostic — works in React Native, Expo, web, Node.",
  "license": "MIT",
  "author": "swift-man",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swift-man/MaterialDesignColor.git",
    "directory": "packages/js"
  },
  "keywords": [
    "material",
    "material-design",
    "material3",
    "material-design-3",
    "colors",
    "color-palette",
    "design-tokens",
    "typescript",
    "react-native",
    "expo"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "node -e \"require('node:fs').copyFileSync('../../LICENSE','LICENSE')\"",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "typescript": "5.4.5"
  }
}
