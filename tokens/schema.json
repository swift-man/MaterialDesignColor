{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Material Design Color Tokens",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" }
  },
  "patternProperties": {
    "^[a-z][A-Za-z0-9]*$": {
      "type": "string",
      "pattern": "^#[0-9A-F]{6}$"
    }
  },
  "additionalProperties": false
}
